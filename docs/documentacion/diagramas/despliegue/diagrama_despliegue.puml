@startuml diagrama_despliegue_produccion

title Diagrama de Despliegue — Entorno de Producción\nSistema de Gestión de Becas Universitarias

skinparam linetype polyline
skinparam nodePadding 20
skinparam packagePadding 15
skinparam node {
  BackgroundColor White
  BorderColor Black
}
skinparam component {
  BackgroundColor #EFF6FF
  BorderColor #1A5276
}
skinparam database {
  BackgroundColor #FDEBD0
  BorderColor #9C640C
}
skinparam cloud {
  BackgroundColor #FDF2E9
  BorderColor #9C640C
}

' ===================== CLIENTE =====================
node "Dispositivo Cliente" <<device>> as cliente {
  component [Navegador Web\n(HTML + Bootstrap 5.3 + HTMX 2.0)] as navegador
}

' ===================== PROVEEDOR SMTP EXTERNO =====================
cloud "Proveedor de Correo SMTP\n(servicio externo)" as smtp {
  component [Servidor SMTP] as smtp_server
}

' ===================== RENDER (PaaS - Cloud) =====================
cloud "Render Cloud Platform" as render {

  node "Edge Router / Load Balancer\n(TLS termination)" <<Render Edge>> as edge {
    component [Reverse Proxy HTTPS] as proxy
  }

  node "Render Web Service\n«becas-web» — plan free" <<Docker Container>> as web_node {
    component [Gunicorn 23 + Django 5.2 (WSGI)\nconfig.settings.production] as django_web
  }

  node "Render Managed PostgreSQL\n«becas-db» — plan free" <<Managed Service>> as db_node {
    database "PostgreSQL 17" as postgres
  }

  node "Render Managed Key-Value\n«becas-redis» — plan starter\n(ipAllowList 0.0.0.0/0)" <<Managed Service>> as redis_node {
    database "Redis 7.4" as redis
  }
}

' ===================== NODO EXTERNO ON-PREMISE =====================
node "PC de Mesa (on-premise)\n\"worker.local\"" <<Physical Machine>> as pc_mesa {

  node "Contenedor Worker\n(docker-compose.worker.yml)" <<Docker Container>> as worker_local_node {
    component [Celery 5.6 Worker + Beat embebido (-B)\ncolas: "celery", "ia"\nScheduler: django-celery-beat\nconfig.settings.production] as celery_local
  }

  node "Contenedor Ollama\n(GPU NVIDIA vía nvidia-container-toolkit)" <<Docker Container>> as ollama_node {
    component [Ollama Server\nmodelo: llama3.1:8b-instruct-q4_K_M] as ollama
  }
}

' ===================== RELACIONES =====================
' Formato de etiqueta: <<protocolo>>\npuerto / detalle

' Cliente -> Render (muchos navegadores, un único edge)
navegador "0..*" --> "1" proxy : <<HTTPS/TLS 1.2+>>\n:443
proxy "1" --> "1" django_web : <<HTTP>>\nX-Forwarded-Proto, :$PORT (interno)

' Web -> DB / Redis (red privada interna de Render)
django_web "1" --> "1" postgres : <<TCP/SQL>>\n:5432 (interno)
django_web "1" ..> "1" redis : <<TCP - Redis Protocol>>\nCELERY_BROKER_URL (interno, sin TLS)\nencola tareas (.delay())

' Worker externo (PC de mesa) -> DB / Redis de Render, por Internet
celery_local "1" --> "1" postgres : <<TCP/SQL sobre Internet>>\n:5432 (host externo)
celery_local "1" <..> "1" redis : <<TCP/TLS - Redis Protocol sobre Internet>>\nbroker + result backend (externo, rediss://)

' Worker externo -> SMTP (único punto de envío de notificaciones, CU27)
celery_local "1" ..> "1" smtp_server : <<SMTP/TLS>>\n:587

' Worker externo -> Ollama local (misma máquina física, red Docker local)
celery_local "1" --> "1" ollama : <<HTTP>>\nOLLAMA_BASE_URL :11434

note right of django_web
  No se conecta nunca con SMTP
  ni con Ollama: el envío de
  notificaciones (apps/notificaciones
  /tasks.py) y la generación de
  resúmenes con IA se delegan al
  worker vía Celery.
end note

note right of celery_local
  Único worker del sistema (no se
  desplegó "becas-worker" en Render).
  Procesa ambas colas, "celery" e "ia":
  - Tareas generales + Beat (ej. CU11
    Cierre de Convocatoria)
  - Tareas de IA (CU23/CU26: resumen
    de reportes vía LLM, chat)
  - Envío de emails (CU27)
end note

note bottom of ollama_node
  Modelo descargado una sola vez al
  iniciar el stack por un contenedor
  "ollama-init" (one-shot, ya finalizado
  en steady-state): ollama pull
  llama3.1:8b-instruct-q4_K_M
end note

note bottom of redis_node
  Redis actúa como:
  - Message broker de Celery
  - Result backend de Celery
end note

@enduml
