@startuml seq_registrar_postulacion

title Diagrama de Secuencia — Iniciar y Registrar Postulación (CU16 + CU17)

actor Estudiante
participant "iniciar_postulacion_view\n(views.py)" as ViewIniciar
participant "enviar_postulacion_view\n(views.py)" as ViewEnviar
participant "postulaciones.services" as Services
participant "Postulacion\n(models.py)" as ModelPost
participant "ContadorReferencia" as Contador
participant "DocumentoPostulacion" as ModelDoc
participant "signals.py" as Signals
participant "notificaciones.receivers" as Receiver
participant "notificaciones.services" as NotifServices
participant "Redis (broker)" as Redis
participant "Celery worker\n(tarea_enviar_email)" as Worker

== CU16 · Iniciar Postulación (estado Borrador) ==

Estudiante -> ViewIniciar : POST elegir convocatoria + beca
activate ViewIniciar
ViewIniciar -> Services : iniciar_postulacion(estudiante, convocatoria, beca)
activate Services

Services -> Services : valida convocatoria.esta_vigente()
alt convocatoria no vigente
  Services --> ViewIniciar : raise ConvocatoriaNoVigenteError
end

Services -> Services : valida beca in convocatoria.becas.all()
alt beca no disponible
  Services --> ViewIniciar : raise BecaNoDisponibleError
end

Services -> ModelPost : ¿existe postulación en\nESTADOS_ACTIVOS para el estudiante?
alt ya existe postulación activa
  Services --> ViewIniciar : raise PostulacionActivaExistenteError
end

Services -> Services : valida formulario.completado == True
alt formulario incompleto
  Services --> ViewIniciar : raise FormularioIncompletoError
end

Services -> ModelPost : Postulacion.objects.create(estado=BORRADOR)
activate ModelPost
ModelPost --> Services : postulacion (Borrador)
deactivate ModelPost
Services --> ViewIniciar : postulacion
deactivate Services
ViewIniciar --> Estudiante : 200 OK — detalle de postulación (Borrador)
deactivate ViewIniciar

== CU17 · Registrar (Enviar) Postulación (Borrador → Enviada) ==

Estudiante -> ViewEnviar : POST enviar postulación
activate ViewEnviar
ViewEnviar -> Services : enviar_postulacion(postulacion)
activate Services

Services -> Services : @transaction.atomic
Services -> ModelPost : valida estado == BORRADOR
alt estado != BORRADOR
  Services --> ViewEnviar : raise TransicionEstadoInvalidaError
end

Services -> Contador : ContadorReferencia.siguiente()
activate Contador
Contador -> Contador : select_for_update()\nultimo_numero += 1
Contador --> Services : numero_referencia
deactivate Contador

Services -> ModelPost : estado=ENVIADA\nfecha_envio=now()\nnumero_referencia=N
activate ModelPost
ModelPost --> Services : ok
deactivate ModelPost

loop por cada TipoDocumento en convocatoria.documentos_requeridos
  Services -> ModelDoc : DocumentoPostulacion.objects.create(\nvalidado=None)
end

Services -> Signals : transaction.on_commit(\n  postulacion_enviada.send(postulacion))
deactivate Services
ViewEnviar --> Estudiante : 200 OK — constancia con numero_referencia
deactivate ViewEnviar

Signals -> Receiver : postulacion_enviada (señal)
activate Receiver
Receiver -> NotifServices : notificar_postulacion_enviada(postulacion)
activate NotifServices
NotifServices -> NotifServices : Notificacion.objects.create(PENDIENTE)
NotifServices -> Redis : tarea_enviar_email.delay(notif.pk)\n(RPUSH cola "celery")
deactivate NotifServices
deactivate Receiver

Redis -> Worker : BLPOP cola "celery"\n(PC externa, worker.local)
activate Worker
Worker -> Worker : send_mail() vía SMTP\nactualiza Notificacion (ENVIADA|ERROR)
deactivate Worker

note over Redis, Worker
  Procesamiento asíncrono: el Estudiante ya recibió
  su respuesta HTTP antes de que el correo se envíe.
  Ver docs/documentacion/diagramas/despliegue/ para
  el detalle de esta comunicación vía Redis.
end note

@enduml
