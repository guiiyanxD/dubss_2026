@startuml seq_convocatoria

title Diagrama de Secuencia — Convocatoria: Crear/Publicar (CU09-CU10) y Cierre Automático (CU11)

actor Director
participant "convocatorias.views" as View
participant "convocatorias.services" as Services
participant "Convocatoria\n(models.py)" as Model
participant "signals.py" as Signals
participant "postulaciones.receivers" as Receiver
participant "postulaciones.services" as PostServices

== CU09 · Crear Convocatoria ==

Director -> View : POST nombre, fechas,\nbecas_ids, documentos_ids
activate View
View -> Services : crear_convocatoria(...)
activate Services
Services -> Services : @transaction.atomic\n_validar_fechas(apertura, cierre)
alt fecha_cierre <= fecha_apertura
  Services --> View : raise FechaInvalidaError
end
Services -> Model : Convocatoria.objects.create(estado=BORRADOR)
Services -> Model : convocatoria.becas.set(becas_ids)\nconvocatoria.documentos_requeridos.set(documentos_ids)
Model --> Services : convocatoria (Borrador)
Services --> View : convocatoria
deactivate Services
View --> Director : 200 OK
deactivate View

== CU10 · Publicar Convocatoria ==

Director -> View : POST publicar(convocatoria_id)
activate View
View -> Services : publicar_convocatoria(convocatoria)
activate Services
Services -> Model : valida estado == BORRADOR
alt estado != BORRADOR
  Services --> View : raise ConvocatoriaNoModificableError
end
Services -> Model : estado = PUBLICADA
Services --> View : convocatoria (Publicada)
deactivate Services
View --> Director : 200 OK
deactivate View

note over Director, Model
  Desde este punto, convocatoria.esta_vigente() == True
  mientras fecha_apertura <= ahora <= fecha_cierre.
  Recién ahora es visible para Estudiantes (CU16).
end note

== CU11 · Cierre Automático de Convocatoria (disparado por Celery Beat) ==

participant "Celery Beat\n(scheduler en BD,\nworker.local)" as Beat
participant "tarea_cerrar_convocatorias\n_vencidas (tasks.py)" as Tarea

Beat -> Beat : DatabaseScheduler evalúa\nPeriodicTask cada hora\n(minute="0", hour="*")
Beat -> Tarea : apply_async()\n(RPUSH cola "celery")
activate Tarea
Tarea -> Services : cerrar_convocatorias_vencidas()
activate Services
Services -> Model : SELECT * WHERE estado=PUBLICADA\nAND fecha_cierre < now()
Model --> Services : convocatorias vencidas

loop por cada convocatoria vencida
  Services -> Services : cerrar_convocatoria(convocatoria)
  Services -> Model : estado = CERRADA
  Services -> Signals : convocatoria_cerrada.send(convocatoria)
end
deactivate Services
deactivate Tarea

Signals -> Receiver : convocatoria_cerrada (señal)
activate Receiver
Receiver -> PostServices : marcar_rechazadas_por_cierre(convocatoria)
activate PostServices
PostServices -> PostServices : UPDATE Postulacion SET\nestado=RECHAZADA_NO_PRESENTACION\nWHERE convocatoria=X AND\nestado IN (BORRADOR, ENVIADA)
deactivate PostServices
deactivate Receiver

note over Beat, Tarea
  Disparador: tarea Beat registrada en la migración
  apps/convocatorias/migrations/0002_registrar_tarea_beat.py.
  Corre en el contenedor worker de la PC externa
  ("worker.local"), no en Render — ver diagrama de despliegue.
end note

@enduml
