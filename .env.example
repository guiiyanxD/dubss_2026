# Django
DJANGO_SECRET_KEY=cambiar-esta-clave-en-produccion-minimo-50-caracteres
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos
POSTGRES_DB=becas_db
POSTGRES_USER=becas_user
POSTGRES_PASSWORD=becas_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (en desarrollo se usa console backend, configurar SMTP para producción)
EMAIL_HOST=smtp.ejemplo.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@ejemplo.com
EMAIL_HOST_PASSWORD=clave-email
EMAIL_USE_TLS=True
