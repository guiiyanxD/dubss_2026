# Variables para correr el worker de Celery (con Beat embebido, -B) en una
# máquina externa a Render — ej. la PC de mesa usada como "servidor" — pero
# conectado a la base de datos y Redis REALES de producción.
#
# Copiar a ".env.worker" (gitignored) y completar con los valores reales del
# dashboard de Render. Usar las connection strings EXTERNAS de becas-db y
# becas-redis, no las internas (las internas solo son alcanzables desde
# dentro de la red de Render).
#
# Importante: si DJANGO_SETTINGS_MODULE no se define acá, config/celery.py y
# config/wsgi.py caen por defecto a config.settings.development. Tiene que
# quedar en config.settings.production sí o sí.

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=<mismo valor configurado en becas-web>

POSTGRES_DB=<Database de becas-db>
POSTGRES_USER=<Username de becas-db>
POSTGRES_PASSWORD=<Password de becas-db>
POSTGRES_HOST=<Hostname EXTERNO de becas-db, no el interno>
POSTGRES_PORT=5432

CELERY_BROKER_URL=<Connection string EXTERNA de becas-redis>
CELERY_RESULT_BACKEND=<misma connection string>

EMAIL_HOST=<SMTP real>
EMAIL_PORT=587
EMAIL_HOST_USER=<usuario SMTP real>
EMAIL_HOST_PASSWORD=<clave SMTP real>
EMAIL_USE_TLS=True

# LLM local (Ollama, contenedor "ollama" definido en docker-compose.worker.yml).
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
